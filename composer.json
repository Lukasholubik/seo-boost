{
    "name": "grou/seo-boost",
    "description": "SEO Booster Pro – Audit Dashboard, Redirect Manager a další SEO nástroje (Grou.cz)",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "brain/monkey": "^2.6"
    },
    "autoload-dev": {
        "psr-4": {
            "SeoBoost\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "vendor-dir": "vendor-dev",
        "platform": {
            "php": "8.0"
        }
    }
}
